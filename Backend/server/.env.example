# ═══════════════════════════════════════════════════════
#  BlockChat v2 — Security-Hardened Configuration
# ═══════════════════════════════════════════════════════

PORT=5000
JWT_SECRET=<64-char-hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# ── Redis (required for queue + rate limiting + nonce store) ──
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=blockchat:

# ── Pinata (IPFS) ──
PINATA_API_KEY=<from Pinata dashboard>
PINATA_SECRET_KEY=<from Pinata dashboard>
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Blockchain ──
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<key>
DEPLOYER_PRIVATE_KEY=<testnet wallet private key>
IDENTITY_REGISTRY_ADDRESS=<after deployment>
GROUP_MANAGER_ADDRESS=<after deployment>
AUDIT_LOG_ADDRESS=<after deployment>

# ── CORS ──
FRONTEND_ORIGIN=http://localhost:3000

# ── Security Tuning ──
NONCE_TTL_SECONDS=60
JWT_EXPIRY=2h
MAX_MESSAGE_BYTES=65536
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_CHALLENGE_PER_MIN=10
RATE_LIMIT_API_PER_MIN=100
RATE_LIMIT_SOCKET_MSG_PER_MIN=60
RATE_LIMIT_UPLOAD_PER_MIN=20

# ── Privacy ──
ENABLE_DUMMY_TRAFFIC=false
BATCH_DELAY_MIN_MS=100
BATCH_DELAY_MAX_MS=500
PENDING_MSG_TTL_SECONDS=86400
PENDING_MSG_MAX_PER_USER=100
